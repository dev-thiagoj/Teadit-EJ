  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Para explorar o ambiente virtual e visualizar a usina por todos os \xE2ngulos,
    o sistema de navega\xE7\xE3o ajusta-se automaticamente ao seu dispositivo.\n\nSe
    estiver utilizando um computador, mantenha o bot\xE3o esquerdo do mouse pressionado
    e arraste o cursor pela tela para orbitar a c\xE2mera ao redor das estruturas.
    \n\nCaso esteja navegando por um dispositivo m\xF3vel, a intera\xE7\xE3o \xE9
    feita inteiramente pelo toque: deslize um dedo sobre a tela para girar a visualiza\xE7\xE3o. "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6b0de76f6cf16b74b8e49746356bbcbc, type: 2}
  m_sharedMaterial: {fileID: 9007510536429424249, guid: 6b0de76f6cf16b74b8e49746356bbcbc, type: 2}
