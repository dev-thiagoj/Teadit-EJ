  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Com um equipamento em destaque, o sistema apresentar\xE1 uma lista das
    solu\xE7\xF5es Teadit recomendadas para aquela aplica\xE7\xE3o espec\xEDfica.
    Ao clicar em um item desta lista, o produto ser\xE1 imediatamente visualizado
    em detalhe na tela.\n\nPara aprofundar seu conhecimento t\xE9cnico, observe o
    link posicionado ao lado do nome de cada produto. Ao clicar nele, uma nova aba
    ser\xE1 aberta automaticamente em seu navegador, direcionando voc\xEA \xE0 p\xE1gina
    oficial da Teadit. L\xE1, voc\xEA ter\xE1 acesso completo \xE0s fichas t\xE9cnicas,
    limites de opera\xE7\xE3o e informa\xE7\xF5es detalhadas sobre a solu\xE7\xE3o
    escolhida."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6b0de76f6cf16b74b8e49746356bbcbc, type: 2}
  m_sharedMaterial: {fileID: 9007510536429424249, guid: 6b0de76f6cf16b74b8e49746356bbcbc, type: 2}
