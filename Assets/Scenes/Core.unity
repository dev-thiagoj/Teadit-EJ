  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Para explorar as solu\xE7\xF5es aplicadas na usina, localize os equipamentos
    sinalizados com \xEDcones numerados. Voc\xEA pode selecion\xE1-los clicando diretamente
    sobre o \xEDcone ou na pr\xF3pria estrutura do equipamento.\n\nAl\xE9m disso,
    a interface oferece duas outras formas de busca: o Bot\xE3o de Lista, para visualizar
    todos os itens pelo nome, e os bot\xF5es laterais da tela, que permitem navegar
    sequencialmente por todos os equipamentos mapeados.\n\nAo ativar um equipamento,
    ele entrar\xE1 em modo de destaque, apresentando automaticamente os produtos
    e solu\xE7\xF5es Teadit recomendados para aquela aplica\xE7\xE3o espec\xEDfica."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6b0de76f6cf16b74b8e49746356bbcbc, type: 2}
