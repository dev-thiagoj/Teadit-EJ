      value: 0
      objectReference: {fileID: 0}
    - target: {fileID: 6080478691892142588, guid: c47c7129aaadd4cc6b8384207b92a9ee, type: 3}
      propertyPath: m_Name
      value: Artigo 3
      objectReference: {fileID: 0}
    - target: {fileID: 7654856920702835011, guid: c47c7129aaadd4cc6b8384207b92a9ee, type: 3}
      propertyPath: m_text
      value: "Para explorar as solu\xE7\xF5es aplicadas na usina, localize os equipamentos
        sinalizados com \xEDcones numerados. Voc\xEA pode selecion\xE1-los clicando
        diretamente sobre o \xEDcone ou na pr\xF3pria estrutura do equipamento.\n\nAl\xE9m
        disso, a interface oferece duas outras formas de busca: o Bot\xE3o de Lista,
        para visualizar todos os itens pelo nome, e os bot\xF5es laterais da tela,
        que permitem navegar sequencialmente por todos os equipamentos mapeados.\n\nAo
        ativar um equipamento, ele entrar\xE1 em modo de destaque, apresentando automaticamente
        os produtos e solu\xE7\xF5es Teadit recomendados para aquela aplica\xE7\xE3o
        espec\xEDfica."
      objectReference: {fileID: 0}
    - target: {fileID: 7654856920702835011, guid: c47c7129aaadd4cc6b8384207b92a9ee, type: 3}
