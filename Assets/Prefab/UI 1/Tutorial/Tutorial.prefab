    - target: {fileID: 6080478691892142588, guid: c47c7129aaadd4cc6b8384207b92a9ee, type: 3}
      propertyPath: m_Name
      value: Artigo 1
      objectReference: {fileID: 0}
    - target: {fileID: 7654856920702835011, guid: c47c7129aaadd4cc6b8384207b92a9ee, type: 3}
      propertyPath: m_text
      value: "Para explorar o ambiente virtual e visualizar a usina por todos os
        \xE2ngulos, o sistema de navega\xE7\xE3o ajusta-se automaticamente ao seu
        dispositivo.\n\nSe estiver utilizando um computador, mantenha o bot\xE3o
        esquerdo do mouse pressionado e arraste o cursor pela tela para orbitar a
        c\xE2mera ao redor das estruturas. \n\nCaso esteja navegando por um dispositivo
        m\xF3vel, a intera\xE7\xE3o \xE9 feita inteiramente pelo toque: deslize um
        dedo sobre a tela para girar a visualiza\xE7\xE3o. "
      objectReference: {fileID: 0}
    - target: {fileID: 7654856920702835011, guid: c47c7129aaadd4cc6b8384207b92a9ee, type: 3}
      propertyPath: m_fontAsset
